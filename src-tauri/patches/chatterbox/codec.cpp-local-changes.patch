+                /IMPLIB:${TTS_BACKBONE_IMPLIB}
+                /DEF:${_ll_deffile}
+                /WHOLEARCHIVE:${_ll_libdir}/Release/llama.lib
+                /WHOLEARCHIVE:${_ll_commondir}/Release/llama-common.lib
+                /WHOLEARCHIVE:${_ll_commondir}/Release/llama-common-base.lib
+                /WHOLEARCHIVE:${_ll_vendordir}/cpp-httplib/Release/cpp-httplib.lib
+                /WHOLEARCHIVE:${_ll_ggmldir}/Release/ggml.lib
