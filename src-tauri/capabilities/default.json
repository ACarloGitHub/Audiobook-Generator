{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window: dialog, fs, http, shell plus our engine commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "fs:default",
    "http:default",
    "shell:default"
  ]
}
