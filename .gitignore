# Audiobook Generator — Local-only artifacts

## TTS model weights (NEVER commit)
# GGUF models downloaded by the user at runtime (hundreds of MB to several GB)
*.gguf
*.bin
# ONNX models (Kokoro, decoders)
*.onnx
# Tokenizer / config files that ship with the models
tokenizer/
voices/
speech_tokenizer/

# Per-engine model directories inside the project tree
audiobook_generator/tts_models/kokoro/*
!audiobook_generator/tts_models/kokoro/.gitkeep
audiobook_generator/tts_models/qwen3tts/*
!audiobook_generator/tts_models/qwen3tts/.gitkeep
audiobook_generator/tts_models/vibevoice/*
!audiobook_generator/tts_models/vibevoice/.gitkeep
audiobook_generator/tts_models/xttsv2/*
!audiobook_generator/tts_models/xttsv2/.gitkeep
tts_models/

# HuggingFace / llama.cpp download caches
.cache/
huggingface/
hf_cache/

