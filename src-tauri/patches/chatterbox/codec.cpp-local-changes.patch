+    # ── Windows: .def file + DLL ──
+    #
+    # MSVC has no version-script equivalent.  We generate a .def file by
+    # running dumpbin /symbols on the static archives and filtering for
+    # llama_* (undecorated C exports) and ?common_sampler*/?common_grammar*
+    # (C++ mangled names).  The DLL then exports ONLY those symbols; all
+    # ggml_* stays hidden inside the DLL, achieving the same isolation as
+    # the Linux version script.
+
+    set(_gen_def_script "${CMAKE_CURRENT_LIST_DIR}/gen_backbone_def.ps1")
+    set(_ll_deffile     "${CMAKE_BINARY_DIR}/ttsbackbone.def")
+
+    # Join archive paths with ';' so PowerShell receives them as a single arg
+    string(REPLACE ";" "," _archives_csv "${_ll_archives}")
+
+    set(TTS_BACKBONE_SO      "${CMAKE_BINARY_DIR}/ttsbackbone/ttsbackbone.dll")
+    set(TTS_BACKBONE_IMPLIB  "${CMAKE_BINARY_DIR}/ttsbackbone/ttsbackbone.lib")
+
+    add_custom_command(
+        OUTPUT  "${_ll_deffile}"
+        COMMAND powershell -ExecutionPolicy Bypass
+                -File "${_gen_def_script}"
+                -Archives "${_archives_csv}"
+                -DefPath "${_ll_deffile}"
+        DEPENDS llama_static ${_ll_archives} "${_gen_def_script}"
+        COMMENT "Generating ttsbackbone.def (symbol isolation for Windows)"
